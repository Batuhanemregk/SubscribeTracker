{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "permissions": {
    "deny": [
      "Read(./apps/mobile/.env)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.p8)",
      "Read(./**/*.keystore)",
      "Read(./**/*.mobileprovision)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"",
            "timeout": 10,
            "statusMessage": "Loading future-work.md"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-doc-nudge.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
