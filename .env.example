# Finify — Mobile App Environment
# Copy to apps/mobile/.env and fill in values.
# Only EXPO_PUBLIC_* vars are exposed to client code.
# NEVER put Supabase service-role keys or RevenueCat sk_ secret keys here.

# Supabase (Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# RevenueCat — PUBLIC platform API keys (appl_ / goog_), NOT the sk_ secret key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_android_key
